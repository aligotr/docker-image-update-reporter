{
    "name": "Go Development (Root)",
    "build": {
        "dockerfile": "Dockerfile"
    },

    "remoteUser": "root",

    "mounts": [
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ],

    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go"
            ]
        }
    }
}
